# Dependencies
# Ignoring node_modules/ at the root will recursively ignore node_modules in both frontend/ and backend/
node_modules/
frontend/node_modules/
backend/node_modules/

# Environment files (sensitive credentials and secrets)
# Ignore all .env files at any level, as well as specific ones
.env
.env.local
backend/.env
frontend/.env

# Build outputs
dist/
dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor and IDE directories/files
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
